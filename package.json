{
  "name": "ddgrok",
  "version": "1.0.0",
  "description": "Datadog Grok Pattern Tester",
  "scripts": {
    "start:server": "cd server && /Users/beni/.cargo/bin/cargo run",
    "start:client": "cd client && npm run dev",
